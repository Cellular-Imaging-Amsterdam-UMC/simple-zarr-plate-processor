{
  "name": "SimpleZarrPlateProcessor",
  "description": "OME-ZARR plate processor: applies Gaussian smoothing to every channel/plane and optionally max-projects along Z",
  "container-image": {
    "image": "cellularimagingcf/simple-zarr-plate-processor",
    "type": "docker"
  },
  "command-line": "python wrapper.py --infolder [INFOLDER] --outfolder [OUTFOLDER] --gtfolder [GTFOLDER] --local -nmc --gaussian_sigma [GAUSSIAN_SIGMA] [DO_MAX_PROJ] --output_name [OUTPUT_NAME] --max_workers [MAX_WORKERS]",
  "inputs": [
    {
      "id": "gaussian_sigma",
      "value-key": "[GAUSSIAN_SIGMA]",
      "command-line-flag": "--gaussian_sigma",
      "name": "Gaussian sigma",
      "description": "Sigma for Gaussian smoothing applied in YX to every plane. Set 0 to disable.",
      "default-value": 2.0,
      "optional": true,
      "type": "Number"
    },
    {
      "id": "do_max_proj",
      "value-key": "[DO_MAX_PROJ]",
      "command-line-flag": "--do_max_proj",
      "name": "Max projection",
      "description": "Perform maximum intensity projection along Z axis",
      "default-value": true,
      "optional": true,
      "type": "Boolean"
    },
    {
      "id": "output_name",
      "value-key": "[OUTPUT_NAME]",
      "command-line-flag": "--output_name",
      "name": "Output plate name",
      "description": "Name for output plate (default: processed)",
      "default-value": "processed",
      "optional": true,
      "type": "String"
    },
    {
      "id": "max_workers",
      "value-key": "[MAX_WORKERS]",
      "command-line-flag": "--max_workers",
      "name": "Parallel workers",
      "description": "Maximum number of parallel worker threads for processing multiple plates",
      "default-value": 4,
      "optional": true,
      "type": "Number"
    }
  ],
  "schema-version": "boutiques-0.5"
}